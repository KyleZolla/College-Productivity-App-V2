<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="0dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/homeCompletedDayTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
        tools:text="Today" />

    <LinearLayout
        android:id="@+id/homeCompletedDayProgressBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/homeCompletedDayStepsSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="3 of 3 steps done" />

        <TextView
            android:id="@+id/homeCompletedDayHoursSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="4.0 of 4.0 hrs done" />

        <ProgressBar
            android:id="@+id/homeCompletedDayHoursProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:max="1000"
            android:progress="0"
            tools:progress="1000" />
    </LinearLayout>

    <TextView
        android:id="@+id/homeCompletedDayAllDoneBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="?attr/colorOnSurface"
        android:visibility="gone"
        tools:text="You completed every step on your plan for today."
        tools:visibility="visible" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/homeCompletedDayToggle"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="0dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:text="@string/home_today_plan_view_completed"
        tools:text="View what you completed" />

    <LinearLayout
        android:id="@+id/homeCompletedDaySteps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:animateLayoutChanges="true"
        android:orientation="vertical"
        android:visibility="gone" />
</LinearLayout>
