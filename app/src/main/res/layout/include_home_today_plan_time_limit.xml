<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeTodayPlanTimeLimitBlock"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:orientation="vertical"
    android:visibility="gone"
    tools:visibility="visible">

    <TextView
        android:id="@+id/homeTodayPlanTimeLimitPrompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/home_today_plan_time_limit_prompt"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?attr/colorOnSurface" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/homeTodayPlanTimeLimitChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true"
        app:selectionRequired="false"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <com.google.android.material.chip.Chip
            android:id="@+id/homeTodayPlanTimeLimit30m"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_today_plan_time_limit_30m" />

        <com.google.android.material.chip.Chip
            android:id="@+id/homeTodayPlanTimeLimit1h"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_today_plan_time_limit_1h" />

        <com.google.android.material.chip.Chip
            android:id="@+id/homeTodayPlanTimeLimit2h"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_today_plan_time_limit_2h" />

        <com.google.android.material.chip.Chip
            android:id="@+id/homeTodayPlanTimeLimitCustom"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_today_plan_time_limit_custom" />

        <com.google.android.material.chip.Chip
            android:id="@+id/homeTodayPlanTimeLimitClear"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_today_plan_time_limit_clear" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:id="@+id/homeTodayPlanTimeLimitStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone"
        tools:text="Today\u2019s plan fits your available time."
        tools:visibility="visible" />
</LinearLayout>
