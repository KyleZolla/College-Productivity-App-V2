<?xml version="1.0" encoding="utf-8"?><!--
   Backup rules for API 31+ (cloud backup and device-to-device transfer).
   Session tokens and the pending OAuth verifier must never leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="auth_prefs.xml" />
        <exclude domain="sharedpref" path="pending_oauth.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="auth_prefs.xml" />
        <exclude domain="sharedpref" path="pending_oauth.xml" />
    </device-transfer>
</data-extraction-rules>
