<?xml version="1.0" encoding="utf-8"?><!--
   Backup rules for API < 31 (Auto Backup / adb backup).
   Session tokens and the pending OAuth verifier must never leave the device.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="auth_prefs.xml" />
    <exclude domain="sharedpref" path="pending_oauth.xml" />
</full-backup-content>
